# =============================================================================
# Nelo Dreams Foundation — production .env (Namecheap shared hosting / cPanel)
# =============================================================================
# Copy this file to /home/USERNAME/laravel-app/.env on the server, then edit
# the placeholders. Lines you MUST edit are marked with  >>EDIT<<

APP_NAME="Nelo Dreams Foundation"
APP_ENV=production
APP_KEY=                              # >>EDIT<<  generate locally with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://YOUR_DOMAIN.com       # >>EDIT<<  e.g. https://nelodreams.org
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ----- MySQL (create the DB + user in cPanel -> "MySQL Databases") -----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=USERNAME_nelo              # >>EDIT<<  cPanel prefixes the DB name with your account name
DB_USERNAME=USERNAME_nelouser          # >>EDIT<<  cPanel prefixes the DB user with your account name
DB_PASSWORD=                           # >>EDIT<<  the password you set when creating the user

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ----- Mail (cPanel email account works; replace with your own values) -------
MAIL_MAILER=smtp
MAIL_HOST=mail.YOUR_DOMAIN.com         # >>EDIT<<
MAIL_PORT=465
MAIL_USERNAME=hello@YOUR_DOMAIN.com    # >>EDIT<<
MAIL_PASSWORD=                         # >>EDIT<<
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="hello@YOUR_DOMAIN.com"  # >>EDIT<<
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ----- One-time deployment helper (delete after running setup.php) -----------
DEPLOY_SECRET=                         # >>EDIT<<  paste a long random string (32+ chars). Generate with: openssl rand -hex 24
